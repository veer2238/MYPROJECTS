{
  "name": "Dental Clinic Professional Theme",
  "dataColors": [
    "#2E86AB",
    "#4CAF50",
    "#F39C12",
    "#E74C3C",
    "#8E44AD",
    "#16A085",
    "#34495E",
    "#1ABC9C"
  ],
  "background": "#F8FAFC",
  "foreground": "#2C3E50",
  "tableAccent": "#2E86AB",
  "visualStyles": {
    "*": {
      "*": {
        "title": [
          {
            "show": true,
            "fontSize": 14,
            "fontFamily": "Segoe UI Semibold",
            "color": { "solid": { "color": "#2C3E50" } }
          }
        ],
        "labels": [
          {
            "color": { "solid": { "color": "#2C3E50" } },
            "fontSize": 11
          }
        ],
        "background": [
          {
            "show": false,
            "color": { "solid": { "color": "#FFFFFF" } }
          }
        ],
        "border": [
          {
            "show": false
          }
        ]
      }
    },
    "card": {
      "*": {
        "labels": [
          {
            "fontSize": 22,
            "color": { "solid": { "color": "#2E86AB" } }
          }
        ],
        "categoryLabels": [
          {
            "show": false
          }
        ]
      }
    },
    "slicer": {
      "*": {
        "items": [
          {
            "color": { "solid": { "color": "#2C3E50" } }
          }
        ],
        "background": [
          {
            "color": { "solid": { "color": "#FFFFFF" } }
          }
        ]
      }
    }
  }
}
