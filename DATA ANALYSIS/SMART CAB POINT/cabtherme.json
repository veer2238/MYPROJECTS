{
  "name": "Smart Cab Premium Clean",
  "dataColors": [
    "#0B3C5D",
    "#328CC1",
    "#D9B310",
    "#FF6F61",
    "#2ECC71",
    "#9B59B6"
  ],
  "background": "#F5F7FA",
  "foreground": "#1D2731",
  "tableAccent": "#328CC1",

  "visualStyles": {
    "*": {
      "*": {
        "fontFamily": "Segoe UI",
        "color": "#1D2731"
      }
    },

    "page": {
      "*": {
        "background": [
          {
            "color": { "solid": { "color": "#F5F7FA" } },
            "transparency": 0
          }
        ]
      }
    },

    "card": {
      "*": {
        "title": [
          {
            "show": true,
            "fontSize": 13,
            "color": { "solid": { "color": "#6B7280" } }
          }
        ],
        "labels": [
          {
            "fontSize": 28,
            "color": { "solid": { "color": "#0B3C5D" } }
          }
        ]
      }
    },

    "slicer": {
      "*": {
        "title": [
          {
            "fontSize": 12,
            "color": { "solid": { "color": "#374151" } }
          }
        ],
        "items": [
          {
            "fontSize": 12,
            "color": { "solid": { "color": "#111827" } }
          }
        ]
      }
    },

    "columnChart": {
      "*": {
        "title": [
          {
            "fontSize": 14
          }
        ]
      }
    },

    "lineChart": {
      "*": {
        "title": [
          {
            "fontSize": 14
          }
        ]
      }
    },

    "pieChart": {
      "*": {
        "legend": [
          {
            "position": "Right"
          }
        ]
      }
    },

    "tableEx": {
      "*": {
        "columnHeaders": [
          {
            "fontSize": 13,
            "color": { "solid": { "color": "#0B3C5D" } }
          }
        ]
      }
    }
  }
}
